[Unit]
Description=SpatialScribe Django
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/spatialscribe
EnvironmentFile=/var/www/spatialscribe/.env
ExecStart=/var/www/spatialscribe/venv/bin/gunicorn \
    config.wsgi:application \
    --workers 3 \
    --bind unix:/run/spatialscribe.sock \
    --access-logfile /var/log/spatialscribe/access.log \
    --error-logfile /var/log/spatialscribe/error.log
Restart=always

[Install]
WantedBy=multi-user.target
